# Used by `npm test` (see tests/setup-env.js). A separate database from dev
# so test runs can freely TRUNCATE tables between tests without touching your
# local dev data. Same Postgres instance (docker compose up -d) is fine -
# just a different database name.
DATABASE_URL=postgresql://grubbuds:grubbuds@localhost:5432/grubbuds_test
JWT_SECRET=test-secret-not-for-real-use
JWT_EXPIRES_IN=7d
NODE_ENV=test
