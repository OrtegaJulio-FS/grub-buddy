PORT=3000
NODE_ENV=development

# Matches docker-compose.yml's postgres service defaults
DATABASE_URL=postgresql://grubbuds:grubbuds@localhost:5432/grubbuds

# Who's allowed to call this API from a browser. Must be an explicit origin
# (never "*") since auth is a cookie and browsers reject wildcard origins on
# credentialed requests. Comma-separate multiple origins (e.g. a staging +
# production frontend URL). Leave unset for local dev - it defaults to Vite's
# default port (http://localhost:5173) unless NODE_ENV is "production", in
# which case an unset value fails closed (blocks all cross-origin requests).
CORS_ORIGIN=

# Used to sign JWTs for /auth/signup and /auth/login. Generate a real one with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Image uploads (spot photos, avatars) - get these from
# https://console.cloudinary.com/console (Dashboard tab). The API secret is
# server-side only - never put it in the frontend's .env.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
