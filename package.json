{
  "name": "grub-buddy",
  "version": "0.1.0",
  "description": "Grubbuds backend - social discovery app for local spots",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node -r dotenv/config node_modules/.bin/node-pg-migrate up",
    "db:migrate:down": "node -r dotenv/config node_modules/.bin/node-pg-migrate down",
    "db:migrate:create": "node-pg-migrate create -j cjs",
    "test": "jest"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "node-pg-migrate": "^9.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
